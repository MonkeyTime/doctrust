{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/document-trust-payload/payment-profile.schema.json",
  "title": "Document Trust Payload Payment Profile",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "intent": { "type": "string", "const": "payment" },
    "issuer": {
      "type": "object",
      "required": ["issuer_id", "trust_anchor_id"],
      "properties": {
        "issuer_id": { "type": "string", "minLength": 1 },
        "trust_anchor_id": { "type": "string", "minLength": 1 }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "document_id",
        "document_type",
        "beneficiary_name",
        "iban",
        "amount",
        "currency",
        "reference",
        "due_date",
        "transaction_id",
        "communication"
      ],
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "document_type": { "type": "string", "const": "invoice" },
        "beneficiary_name": { "type": "string", "minLength": 1 },
        "iban": { "type": "string", "minLength": 10 },
        "amount": { "type": ["number", "string"] },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "reference": { "type": "string", "minLength": 1 },
        "due_date": { "type": "string", "minLength": 1 },
        "transaction_id": { "type": "string", "minLength": 1 },
        "communication": { "type": "string", "minLength": 1 }
      }
    }
  }
}
